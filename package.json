    "cors": "^2.8.5",
    "helmet": "^7.0.0"
  },
  "devDependencies": {
    "jest": "^29.5.0",
    "supertest": "^6.3.3",
    "eslint": "^8.40.0",
    "nodemon": "^2.0.20",
    "@jest/globals": "^29.5.0"
  }
}
