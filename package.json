{
  "name": "jenkins-demo-app",
  "version": "1.0.0",
  "description": "Node.js application for Jenkins to GitHub Actions migration",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "test": "jest --coverage --testPathIgnorePatterns=/node_modules/",
